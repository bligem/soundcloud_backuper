# SoundCloud artist profile URL to back up
SOUNDCLOUD_ARTIST_URL=https://soundcloud.com/enilylbmessa

# Output directory (relative or absolute)
OUTPUT_DIR=backup

# --- Authentication ---
# SoundCloud no longer supports email/password login from third-party tools
# (hCaptcha blocks it). Use ONE of the two options below.

# Option A (recommended): let yt-dlp read cookies directly from your browser.
#   1. Log in to soundcloud.com in that browser.
#   2. FULLY CLOSE the browser (its cookie DB is locked while running).
#   3. Set this to one of: firefox, chrome, chromium, brave, edge, opera, vivaldi, safari
COOKIES_FROM_BROWSER=

# Option B: paste the oauth_token cookie value manually.
#   Firefox: F12 -> Storage tab -> Cookies -> https://soundcloud.com -> copy `oauth_token`.
#   Chrome:  F12 -> Application tab -> Cookies -> https://soundcloud.com -> copy `oauth_token`.
SOUNDCLOUD_OAUTH_TOKEN=
